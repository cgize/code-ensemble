{
  "stateFile": ".opencode/state/code-ensemble.json",
  "roles": {
    "director": {
      "model": "opencode-go/minimax-m3",
      "mode": "primary",
      "promptFile": "prompts/director.md"
    },
    "explorer": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high",
      "mode": "subagent",
      "promptFile": "prompts/explorer.md"
    },
    "researcher": {
      "model": "opencode-go/qwen3.7-plus",
      "mode": "subagent",
      "promptFile": "prompts/researcher.md"
    },
    "visualizer": {
      "model": "opencode-go/kimi-k2.7-code",
      "mode": "subagent",
      "promptFile": "prompts/visualizer.md"
    },
    "planner": {
      "model": "openai/gpt-5.6-terra",
      "variant": "xhigh",
      "mode": "subagent",
      "promptFile": "prompts/planner.md",
      "fallbacks": ["opencode-go/glm-5.2"]
    },
    "architect": {
      "model": "openai/gpt-5.6-sol",
      "variant": "xhigh",
      "mode": "subagent",
      "promptFile": "prompts/architect.md",
      "fallbacks": ["opencode-go/glm-5.2"]
    },
    "implementer": {
      "model": "opencode-go/glm-5.2",
      "mode": "subagent",
      "promptFile": "prompts/implementer.md"
    },
    "reviewer": {
      "model": "opencode-go/deepseek-v4-pro",
      "mode": "subagent",
      "promptFile": "prompts/reviewer.md"
    },
    "tester": {
      "model": "opencode-go/mimo-v2.5",
      "mode": "subagent",
      "promptFile": "prompts/tester.md"
    }
  },
  "commands": {
    "phase-status": "commands/phase-status.md",
    "approve-phase": "commands/approve-phase.md",
    "force-phase": "commands/force-phase.md",
    "reset-phase": "commands/reset-phase.md",
    "auto-loop": "commands/auto-loop.md"
  },
  "transitions": {
    "reviewToPlanOnlyWithFindings": true,
    "autoLoop": false,
    "autoLoopMaxIterations": 5
  }
}
