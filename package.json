{
  "name": "@cgize/code-ensemble",
  "version": "1.0.4",
  "private": false,
  "description": "An OpenCode plugin that coordinates planning, implementation, and review",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cgize/code-ensemble.git"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": [
    "dist/*.js",
    "dist/*.d.ts",
    "defaults",
    "README.md",
    "INSTALL.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "lint": "eslint .",
    "smoke:package": "npm run build && node scripts/smoke-package.mjs"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.18.1",
    "proper-lockfile": "4.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "4.1.4",
    "eslint": "^9.12.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "trustedDependencies": [
    "esbuild",
    "msgpackr-extract"
  ],
  "allowScripts": {
    "esbuild@0.28.1": true,
    "msgpackr-extract@3.0.4": true
  }
}
