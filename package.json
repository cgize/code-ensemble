{
  "name": "@cgize/code-ensemble",
  "version": "0.0.7",
  "private": false,
  "type": "module",
  "files": [
    "dist/*.js",
    "defaults",
    "README.md",
    "INSTALL.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./internal": {
      "import": "./dist/internal.js",
      "require": "./dist/internal.js",
      "types": "./dist/internal.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.12.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "trustedDependencies": [
    "esbuild",
    "msgpackr-extract"
  ],
  "allowScripts": {
    "esbuild@0.28.1": true,
    "msgpackr-extract@3.0.4": true
  }
}
